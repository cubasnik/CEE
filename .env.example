# OpenStack authentication (required)
OS_AUTH_URL=http://openstack.example.com:5000/v3
OS_USERNAME=admin
OS_PASSWORD=change-me
OS_PROJECT_NAME=admin
OS_USER_DOMAIN_NAME=Default

# OpenStack authentication (commonly required by cloud config)
OS_PROJECT_DOMAIN_NAME=Default

# Optional
OS_REGION_NAME=RegionOne
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3

# App settings
CORS_ORIGINS=*
